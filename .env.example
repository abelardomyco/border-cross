# Border Crossing Dashboard — environment template
# Values here are placeholders. Do NOT commit real secrets.

# =========================
# Runtime / app identity
# =========================
APP_ENV=development

# =========================
# Official waits connector (CBP / official sources)
# =========================
# Future: used by a server-side connector that replaces mock live builders.
CBP_WAIT_TIMES_SOURCE=mock
# Example if you later proxy/normalize an upstream feed:
# CBP_WAIT_TIMES_URL=https://example.com/cbp/waits.json

# =========================
# Google Routes (approach congestion)
# =========================
# Future: used by the approach congestion module to fetch traffic-aware travel times.
GOOGLE_MAPS_API_KEY=__REPLACE_ME__
GOOGLE_ROUTES_REGION=us

# =========================
# Camera + screenshot evidence storage
# =========================
# Future: upload screenshots to object storage and return signed URLs.
EVIDENCE_STORAGE_PROVIDER=mock
EVIDENCE_STORAGE_BUCKET=__REPLACE_ME__
EVIDENCE_STORAGE_PUBLIC_BASE_URL=__REPLACE_ME__

# =========================
# Video AI / CV pipeline
# =========================
# Future: where you call a CV inference service (edge function / GPU worker / vendor).
CV_INFERENCE_ENDPOINT=__REPLACE_ME__
CV_INFERENCE_API_KEY=__REPLACE_ME__

# =========================
# Optional database (for production ingestion/history)
# =========================
# If you later persist uploads, telemetry, and analytics:
DATABASE_URL=__REPLACE_ME__

